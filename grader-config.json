{
  "schemaVersion": "1.0",
  "templateSlug": "sec-rbac-audit-trail",
  "evaluationBlocks": [
    {
      "blockId": "auto",
      "evaluationType": "automated_pipeline",
      "metrics": [
        {
          "metricKey": "rbac_implemented",
          "worker": "SASTWorker",
          "weight": 30,
          "threshold": 1.0,
          "config": {
            "requiredPatterns": ["authorize", "PERMISSIONS", "role", "forbidden"],
            "targetFiles": ["src/authorization/**/*.ts"]
          }
        },
        {
          "metricKey": "audit_log_present",
          "worker": "SASTWorker",
          "weight": 20,
          "threshold": 1.0,
          "config": {
            "requiredPatterns": ["audit_log", "request_id", "occurred_at"],
            "targetFiles": ["migrations/002_audit_log.sql"]
          }
        },
        {
          "metricKey": "authorization_test_coverage",
          "worker": "MetricsWorker",
          "weight": 25,
          "threshold": 0.8,
          "config": {
            "tool": "jest",
            "coverageDir": "tests/authorization/",
            "minCoverage": 0.8
          }
        },
        {
          "metricKey": "test_pass_rate",
          "worker": "MetricsWorker",
          "weight": 15,
          "threshold": 1.0,
          "config": {
            "tool": "jest",
            "requireAll": true
          }
        },
        {
          "metricKey": "sast_findings",
          "worker": "SASTWorker",
          "weight": 10,
          "threshold": 0,
          "config": {
            "severity": "HIGH",
            "targetFiles": ["src/**/*.ts"]
          }
        }
      ]
    }
  ]
}
